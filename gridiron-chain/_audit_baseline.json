      "label": "mff_completion_allowed",
      "pattern": "League completion-allowed:\\s+([0-9.]+)%",
      "value": 65.2, "tol": 2.5, "nfl": [58, 69]
    },
    {
      "audit": "_sim_audit.js", "args": ["2"],
      "label": "sim_points_per_game",
