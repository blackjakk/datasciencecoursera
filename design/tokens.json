{
  "_readme": [
    "THE single source of design truth for every MONEYLEAGUE UI surface.",
    "Edit this file, run `python3 design/build_design.py`, commit all three",
    "(tokens.json, ml.css, tokens.py). Never hardcode a hex anywhere else —",
    "scripts/check_design_system.py fails the build if you do.",
    "All color values are WCAG-AA verified (docs/DESIGN_SYSTEM.md has the",
    "measured ratios and on-color polarity table) — re-verify before changing."
  ],
  "color": {
    "position": {
      "QB": "#dc2626",
      "RB": "#0e7490",
      "WR": "#15803d",
      "TE": "#f59e0b",
      "K": "#9a3412",
      "DEF": "#6b6b6b"
    },
    "position_text": {
      "_comment": "on-badge text polarity per position (C20); default #fff",
      "TE": "#000"
    },
    "semantic": {
      "success": { "light": "#15803d", "dark": "#4ade80" },
      "warn":    { "light": "#b45309", "dark": "#f59e0b" },
      "danger":  { "light": "#c81e1e", "dark": "#f87171" },
      "info":    { "light": "#0369a1", "dark": "#60a5fa" },
      "keeper":  { "light": "#0369a1", "dark": "#60a5fa" },
      "focus":   { "light": "#0369a1", "dark": "#7dd3fc" }
    },
    "surface": {
      "dark": {
        "bg": "#0b0d10", "panel": "#14171c", "panel2": "#1c2027",
        "border": "#262b33", "border_strong": "#66707d", "row": "#1a1d22",
        "text": "#e8eaee", "muted": "#8a93a0"
      },
      "light": {
        "bg": "#ffffff", "panel": "#ffffff", "panel2": "#f1f5f9",
        "border": "#d8dce2", "border_strong": "#767f8b", "row": "#f0f2f5",
        "text": "#1a1d24", "muted": "#5d6673"
      }
    },
    "highlight": {
      "target": { "dark": "rgba(74,222,128,.16)", "light": "rgba(21,128,61,.10)" },
      "mine":   { "dark": "rgba(74,222,128,.18)", "light": "rgba(21,128,61,.12)" }
    },
    "banner": {
      "warn_bg": "#fff7ed", "warn_border": "#fed7aa"
    },
    "chart": {
      "grid": "#e5e7eb", "grid_strong": "#d1d5db"
    },
    "brand": {
      "header_a": "#0f766e", "header_b": "#0e7490", "on_brand": "#ffffff"
    },
    "palette": {
      "gold": "#d4a017", "navy": "#0a3d62", "teal": "#1f7a8c",
      "emerald": "#2d6a4f", "orange": "#dd6e42", "crimson": "#a23737",
      "slate": "#3d405b", "cream": "#f7f4ea", "ink": "#1a1d24",
      "gray": "#6b7280"
    },
    "manager": {
      "trevor_bergerboy": "#2d6a4f",
      "coop": "#1f3a5f",
      "dave_aka_wang": "#8b1e3f",
      "kyle_figgy": "#f59e0b",
      "brower_barry": "#0891b2",
      "ankur_patel": "#7c3aed",
      "eric_m": "#dc2626",
      "troy_mullings": "#15803d",
      "brian_bigguap": "#1e40af",
      "lem": "#65a30d",
      "donnie": "#9a3412",
      "tim_breswick": "#0f172a",
      "josh_wildboy": "#a855f7",
      "nark": "#78716c",
      "jp_former": "#525252",
      "nick_lewis_left": "#737373",
      "notebooks_left": "#a3a3a3"
    }
