  "typography": {
    "display": "'Bebas Neue', 'Arial Narrow', sans-serif",
    "body": "'Inter', -apple-system, 'Segoe UI', sans-serif",
    "font_dir": "data/fonts"
  },
  "radius": { "sm": "3px", "md": "5px", "lg": "8px" },
